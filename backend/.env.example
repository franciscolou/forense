# Copy to .env and adjust. All values have sensible dev defaults in config.py.

# SQLite (default, zero infra):
DATABASE_URL=sqlite+aiosqlite:///./forense.db
# Postgres (production):
# DATABASE_URL=postgresql+asyncpg://forense:forense@localhost:5432/forense

SECRET_KEY=change-me-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DEBUG=true
